rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Photos live at {uid}/{date}/{kind}-{timestamp}.{ext}.
    // Replaces the storage.objects RLS policies that gated reads,
    // writes, and deletes by auth.uid()::text = first folder.
    match /{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
